---
import { Image } from 'astro:assets';
import StoryStep from '../StoryStep.astro';
import Canvas from '../Canvas.astro';
import Item from '../Item.astro';
import peachtree from '../../assets/peachtree/peachtree.png';
---

<StoryStep title={'"Peachtree"'} mediaFirst>
	<Canvas slot="media" fill fitScale class="cluster">
		<Item left="0%" top="0%" width="100%">
			<Image src={peachtree} alt="Standing Peachtree" />
		</Item>
	</Canvas>

	<div class="copy">
		<p>Atlanta's future site sat right between these two tribes.</p>
		<p>
			On the Muscogee side stood a village called Standing Peachtree—and that's
			where every Peachtree street in the city gets its name.
		</p>
		<p>The most-repeated word in Atlanta belongs to a place the city erased.</p>
	</div>
</StoryStep>

<style>
	/* extra breathing room below the body text, before the prev/next bar */
	.copy {
		padding-bottom: 1.5rem;
	}
</style>
