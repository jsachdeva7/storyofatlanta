---
import { Image } from 'astro:assets';
import StoryStep from '../StoryStep.astro';
import Canvas from '../Canvas.astro';
import Item from '../Item.astro';
import sweetAuburn from '../../assets/sweet-auburn/sweetauburn.png';
import sign from '../../assets/sweet-auburn/sign.png';
---

<StoryStep title="Sweet Auburn">
	<p>
		Locked out of white Atlanta, Black Atlanta built its own.
		Auburn Avenue filled with Black-owned banks, insurance companies, newspapers,
		churches, and nightclubs.
	</p>
	<p>
		But it rose in the shadow of violence. In 1906, white mobs killed Black
		Atlantans across the city—and Auburn grew, in part, because Black Atlanta
		needed ground of its own to be safe.
	</p>

	<!-- Free-flow pocket: drag/resize/rotate these with ?edit. -->
	<Canvas slot="media" fill fitScale class="cluster">
		<Item
			class="raise-phone"
			left="21.4%"
			top="13%"
			width="78.8%"
			phone={{ left: '1.3%', top: '37.1%', width: '98%', rotate: 4.1 }}
		>
			<Image src={sweetAuburn} alt="Auburn Avenue" />
		</Item>
		<Item
			left="-1.3%"
			top="1.3%"
			width="29.8%"
			rotate={-5.3}
			phone={{ left: '37.7%', top: '0.2%', width: '45.7%', rotate: -3.6 }}
		>
			<Image src={sign} alt="Auburn Avenue sign" />
		</Item>
	</Canvas>
</StoryStep>
