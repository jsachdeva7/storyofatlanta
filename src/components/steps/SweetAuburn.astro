---
import { Image } from 'astro:assets';
import StoryStep from '../StoryStep.astro';
import Canvas from '../Canvas.astro';
import Item from '../Item.astro';
import sweetAuburn from '../../assets/sweet-auburn/sweetauburn.png';
import sign from '../../assets/sweet-auburn/sign.png';
import lugenia from '../../assets/sweet-auburn/lugenia.png';
---

<StoryStep title="Sweet Auburn">
	<p>
		Locked out of white Atlanta, Black Atlanta built its own.
		Auburn Avenue filled with Black-owned banks, insurance companies, newspapers,
		churches, and nightclubs.
	</p>
	<p>
		Women like Lugenia Burns Hope built the schools, clinics, and relief programs that held it all together. Auburn wasn't just rich—it was a city within a city, built to take care of its own.
	</p>

	<!-- Free-flow pocket: drag/resize/rotate these with ?edit. -->
	<Canvas slot="media" fill fitScale class="cluster">
		<!-- DOM order = back → front: sign, sweetauburn, lugenia (front) -->
		<Item
			left="54.2%"
			top="-3.7%"
			width="29.8%"
			rotate={-5.3}
			phone={{ left: '50.6%', top: '0%', width: '45.7%', rotate: -3.6 }}
		>
			<Image src={sign} alt="Auburn Avenue sign" />
		</Item>
		<Item
			class="raise-phone"
			left="17.9%"
			top="20%"
			width="78.8%"
			rotate={-1.3}
			phone={{ left: '1.4%', top: '37.1%', width: '98%', rotate: 4.1 }}
		>
			<Image src={sweetAuburn} alt="Auburn Avenue" />
		</Item>
		<Item
			left="1.7%"
			top="2.4%"
			width="29.7%"
			rotate={4.4}
			phone={{ left: '3.2%', top: '0%', width: '39.6%', rotate: 4.4 }}
		>
			<Image src={lugenia} alt="Lugenia Burns Hope" />
		</Item>
	</Canvas>
</StoryStep>
