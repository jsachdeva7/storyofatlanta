---
import { Image } from 'astro:assets';
import StoryStep from '../StoryStep.astro';
import Canvas from '../Canvas.astro';
import Item from '../Item.astro';
import resurgens from '../../assets/new-south/resurgens.png';
import georgiaTech from '../../assets/new-south/georgiatech.png';
import cokeBottle from '../../assets/new-south/cokebottle.png';
---

<StoryStep title="The New South" mediaFirst>
	<!-- Free-flow pocket: drag/resize/rotate these with ?edit. -->
	<Canvas slot="media" fill fitScale class="cluster">
		<Item
			left="-0.3%"
			top="9.8%"
			width="38.9%"
			rotate={-6.1}
			phone={{ left: '0.6%', top: '4.7%', width: '58.8%', rotate: -6.1 }}
		>
			<Image src={resurgens} alt="Resurgens — the phoenix" />
		</Item>
		<Item
			left="1.1%"
			top="27.5%"
			width="75.6%"
			phone={{ left: '0.4%', top: '43%', width: '81.4%' }}
		>
			<Image src={georgiaTech} alt="The Georgia School of Technology" />
		</Item>
		<Item
			left="75.7%"
			top="4.6%"
			width="19.8%"
			rotate={5.2}
			phone={{ left: '73.7%', top: '2.1%', width: '25.3%', rotate: 4.8 }}
		>
			<Image src={cokeBottle} alt="Coca-Cola bottle" />
		</Item>
	</Canvas>

	<div class="copy">
		<p>
			Atlanta took a phoenix as its symbol and one word as its motto—Resurgens,
			rising again. It bet everything on a "New South" of factories and
			commerce.
		</p>
		<p>
			In 1885 it founded a school to build that future—the Georgia School of
			Technology. A year later, a local pharmacist's headache
			syrup became Coca-Cola, and Atlanta started selling itself to the world.
		</p>
	</div>
</StoryStep>

<style>
	/* breathing room below the body text, before the prev/next bar */
	.copy {
		padding-bottom: 1.5rem;
	}
</style>
