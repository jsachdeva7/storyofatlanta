---
import { Image } from 'astro:assets';
import StoryStep from '../StoryStep.astro';
import Canvas from '../Canvas.astro';
import Item from '../Item.astro';
import spelman from '../../assets/after-slavery/spelman.png';
import voters from '../../assets/after-slavery/voters.png';
import sign from '../../assets/after-slavery/sign.png';
---

<StoryStep title="After Slavery" mediaFirst>
	<!-- Free-flow pocket: drag/resize/rotate these with ?edit. -->
	<Canvas slot="media" fill fitScale class="cluster">
		<Item
			left="-6.3%"
			top="3.8%"
			width="50%"
			rotate={-5}
			phone={{ left: '-6.4%', top: '3.8%', width: '59.8%', rotate: -5 }}
		>
			<Image src={voters} alt="Black Atlantans voting" />
		</Item>
		<Item
			left="46.1%"
			top="4.4%"
			width="55.7%"
			rotate={5.9}
			phone={{ left: '41.9%', top: '11.7%', width: '64%', rotate: 5.9 }}
		>
			<Image src={spelman} alt="Spelman College" />
		</Item>
		<Item
			left="26.8%"
			top="55.4%"
			width="64.9%"
			rotate={-3.9}
			phone={{ left: '18.4%', top: '62.2%', width: '71.1%', rotate: -3.9 }}
		>
			<Image src={sign} alt="Segregation sign" />
		</Item>
	</Canvas>

	<div class="copy">
		<p>
			For one brief decade, Black Atlantans voted, held office, and built
			institutions meant to last. A cluster of Black colleges rose in the city:
			the schools that became the Atlanta University Center.
		</p>
		<p>
			Then, inequality was restored. Over the next decades, the freedom was walled
			back up by law: separate, unequal, and enforced by violence.
		</p>
	</div>
</StoryStep>

<style>
	/* breathing room below the body text, before the prev/next bar */
	.copy {
		padding-bottom: 1.5rem;
	}
	/* more gap between the canvas and the copy on phone */
	:global(:root[data-bp='phone']) .copy {
		margin-top: 1rem;
	}
</style>
