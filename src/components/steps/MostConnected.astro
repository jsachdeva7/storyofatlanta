---
import { Image } from 'astro:assets';
import StoryStep from '../StoryStep.astro';
import Canvas from '../Canvas.astro';
import Item from '../Item.astro';
import plane from '../../assets/most-connected/plane.png';
import cnn from '../../assets/most-connected/cnn.png';
import airportSigns from '../../assets/most-connected/airport-signs.png';
---

<StoryStep title="Most Connected">
	<p>
		Atlanta kept pulling people in—Black Americans moving back South by the
		millions, and then built the infrastructure to match.
	</p>
	<p>
		In 1980, a local station called CNN started broadcasting news 24 hours a day,
		and the world started watching Atlanta. Named after Mayor Jackson, Atlanta's airport became the busiest on
		Earth.
	</p>

	<!-- Free-flow pocket: drag/resize/rotate these with ?edit.
	     DOM order = back → front: airportSigns, plane, cnn -->
	<Canvas slot="media" fill fitScale class="cluster">
		<Item left="1%" top="20.2%" width="55%" rotate={6.2}>
			<Image src={airportSigns} alt="Airport signage" />
		</Item>
		<Item left="1.6%" top="43.6%" width="96.1%" rotate={3.3}>
			<Image src={plane} alt="Hartsfield–Jackson Atlanta International Airport" />
		</Item>
		<Item left="41.5%" top="8.2%" width="58.1%" rotate={-2.4}>
			<Image src={cnn} alt="CNN Center" />
		</Item>
	</Canvas>
</StoryStep>
