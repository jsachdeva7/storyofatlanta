---
/* Standard layout for story steps past the hero:
   - title (kicker) at the top
   - an elastic `media` slot (a <Canvas>) that fills the leftover height
   - body text (default slot)

   `mediaFirst` puts the canvas above the body text (else text above canvas). */
interface Props {
	title: string;
	mediaFirst?: boolean;
}
const { title, mediaFirst = false } = Astro.props;
const hasBody = Astro.slots.has('default');
const hasMedia = Astro.slots.has('media');
---

<section class="sstep">
	<p class="kicker">{title}</p>

	{hasMedia && mediaFirst && <div class="sstep__media"><slot name="media" /></div>}

	{hasBody && (
		<div class:list={['sstep__body', 'lede', !hasMedia && 'sstep__body--center']}>
			<slot />
		</div>
	)}

	{hasMedia && !mediaFirst && (
		<div class="sstep__media sstep__media--bottom"><slot name="media" /></div>
	)}
</section>

<style>
	.sstep {
		/* exactly one window tall (definite height) so the flex:1 canvas can
		   absorb the leftover space instead of the slide growing past it */
		height: 100dvh;
		display: flex;
		flex-direction: column;
		box-sizing: border-box;
		text-align: center;
		padding: clamp(1.5rem, 4vh, 3.5rem) 2rem;
		gap: clamp(0.9rem, 2.5vh, 1.75rem);
	}
	:global(:root[data-bp='phone']) .sstep {
		padding-inline: 15px;
		gap: 0.8rem;
	}
	/* elastic canvas zone: fills whatever vertical space is left */
	.sstep__media {
		flex: 1 1 auto;
		min-height: 0;
		display: grid;
	}
	/* a little breathing room below a bottom canvas */
	.sstep__media--bottom {
		margin-bottom: 1.5rem;
	}
	/* body copy reads left-aligned under the centred title */
	.sstep__body {
		text-align: left;
	}
	/* no-canvas slide: let the body fill and centre vertically */
	.sstep__body--center {
		flex: 1 1 auto;
		min-height: 0;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}
</style>
