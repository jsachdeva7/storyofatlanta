---
/* ============================================================
   DEV-ONLY editing tools. To ship production, delete the single
   <EditTools /> line in Story.astro (and optionally this file).
   Everything below — the toggle button, the panel, the drag/
   resize/rotate behaviour, and all edit-mode styling — goes with it.
   ============================================================ */
---

<button class="edit-toggle" data-edit-toggle type="button" aria-pressed="false">edit</button>

<aside class="edit-panel" data-panel hidden>
	<div class="edit-panel__devices">
		<button type="button" data-device="desktop" class="is-on">desktop</button>
		<button type="button" data-device="tablet">tablet</button>
		<button type="button" data-device="phone">phone</button>
	</div>
	<div class="edit-panel__readout" data-readout>No item selected</div>
	<button type="button" data-copy>Copy canvas</button>
	<p class="edit-panel__hint">Drag to move · corner to resize · knob to rotate</p>
</aside>

<script>
	import { setupEditTools } from '../scripts/edit-mode';

	setupEditTools();

	const btn = document.querySelector('[data-edit-toggle]') as HTMLButtonElement | null;
	const panel = document.querySelector('[data-panel]') as HTMLElement | null;

	btn?.addEventListener('click', () => {
		const on = document.body.classList.toggle('editing');
		btn.setAttribute('aria-pressed', String(on));
		btn.classList.toggle('is-on', on);
		btn.textContent = on ? 'editing' : 'edit';
		if (panel) panel.hidden = !on;
	});

	// Device preview: shrink the stage to a device width AND force the
	// matching breakpoint, so you can author mobile layouts on a wide screen.
	const root = document.documentElement;
	const deviceBtns = Array.from(
		document.querySelectorAll('[data-device]')
	) as HTMLButtonElement[];

	deviceBtns.forEach((b) => {
		b.addEventListener('click', () => {
			const device = b.dataset.device as 'desktop' | 'tablet' | 'phone';
			deviceBtns.forEach((x) => x.classList.toggle('is-on', x === b));
			document.body.classList.remove('preview-tablet', 'preview-phone');

			if (device === 'desktop') {
				delete root.dataset.bpLock; // hand control back to the window
				window.dispatchEvent(new Event('resize'));
			} else {
				root.dataset.bpLock = '1'; // take control from the window
				root.dataset.bp = device;
				document.body.classList.add(`preview-${device}`);
			}
		});
	});
</script>

<style is:global>
	/* ---- Toggle button: fixed at the true top-right of the browser ---- */
	.edit-toggle {
		position: fixed;
		top: 12px;
		right: 12px;
		z-index: 10000;
		appearance: none;
		-webkit-appearance: none;
		font: 600 12px/1 ui-monospace, SFMono-Regular, Menlo, monospace;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #f1efe9;
		background: rgba(8, 6, 14, 0.7);
		border: 1px solid rgba(255, 255, 255, 0.3);
		border-radius: 6px;
		padding: 7px 12px;
		cursor: pointer;
		backdrop-filter: blur(4px);
	}
	.edit-toggle.is-on {
		background: #4da3ff;
		border-color: #4da3ff;
		color: #08060e;
	}

	/* ---- Device preview: constrain the stage to a real device frame ----
	   iPhone 13/14 Pro / 15 / 16: 393px wide; height 748 (address bar shown)
	   to 852 (hidden). We preview at the tighter 748 so a layout that fits
	   here also fits when the bar hides. */
	body.preview-tablet .stage {
		width: 740px;
		max-width: 740px;
		margin-block: 24px;
	}
	body.preview-phone .stage {
		box-sizing: border-box; /* 748px includes padding/border, like a real screen */
		width: 393px;
		max-width: 393px;
		height: 748px;
		min-height: 748px;
		margin-block: 24px;
		overflow-y: auto;
	}
	/* the step normally fills 100dvh — inside the phone frame it must fill
	   the simulated phone height instead, not the desktop window height */
	body.preview-phone .step {
		box-sizing: border-box; /* padding counts toward the 748px, not added on top */
		min-height: 748px;
	}
	body.preview-tablet .stage,
	body.preview-phone .stage {
		outline: 1px solid rgba(255, 255, 255, 0.15);
	}

	/* ---- Editing affordances (only visible when body.editing) ---- */
	body.editing .stage {
		border-left-color: rgba(255, 255, 255, 0.3);
		border-right-color: rgba(255, 255, 255, 0.3);
	}
	body.editing .pocket {
		outline: 1px dashed rgba(255, 255, 255, 0.2);
	}
	body.editing .item {
		outline: 1px dashed rgba(255, 255, 255, 0.6);
		cursor: grab;
	}
	body.editing .item.selected {
		outline: 1px solid #4da3ff;
	}
	body.editing .item.selected .item__handle {
		display: block;
	}

	.item__handle {
		display: none;
		position: absolute;
		box-sizing: border-box;
	}
	.item__handle--resize {
		width: 14px;
		height: 14px;
		right: -7px;
		bottom: -7px;
		background: #4da3ff;
		border: 2px solid #fff;
		border-radius: 2px;
		cursor: nwse-resize;
	}
	.item__handle--rotate {
		width: 14px;
		height: 14px;
		left: 50%;
		top: -28px;
		margin-left: -7px;
		background: #fff;
		border: 2px solid #4da3ff;
		border-radius: 50%;
		cursor: grab;
	}

	/* ---- Device toggle row ---- */
	.edit-panel__devices {
		display: flex;
		gap: 6px;
		margin-bottom: 10px;
	}
	.edit-panel__devices button {
		flex: 1;
		font: inherit;
		cursor: pointer;
		background: transparent;
		color: #f1efe9;
		border: 1px solid rgba(255, 255, 255, 0.25);
		border-radius: 4px;
		padding: 5px 6px;
	}
	.edit-panel__devices button.is-on {
		background: #4da3ff;
		color: #08060e;
		border-color: #4da3ff;
		font-weight: 700;
	}

	/* ---- Readout / copy panel ---- */
	.edit-panel {
		position: fixed;
		bottom: 16px;
		left: 16px;
		z-index: 10000;
		background: rgba(8, 6, 14, 0.92);
		color: #fff;
		border: 1px solid rgba(255, 255, 255, 0.25);
		border-radius: 8px;
		padding: 12px 14px;
		font: 12px/1.5 ui-monospace, SFMono-Regular, Menlo, monospace;
		max-width: 320px;
	}
	.edit-panel__readout {
		white-space: pre-wrap;
		margin-bottom: 8px;
	}
	.edit-panel button {
		font: inherit;
		cursor: pointer;
		background: #4da3ff;
		color: #08060e;
		border: 0;
		border-radius: 4px;
		padding: 6px 10px;
		font-weight: 700;
	}
	.edit-panel__hint {
		margin: 8px 0 0;
		opacity: 0.6;
	}
</style>
