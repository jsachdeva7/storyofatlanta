---
import { Icon } from 'astro-icon/components';

/* The bordered "next" call-to-action. Advances the story (scripts/story.ts).
   Shared button styling lives in global.css (.cta), reused by <Back>. */
interface Props {
	label?: string;
}
const { label = 'next' } = Astro.props;
---

<button class="cta" type="button" data-advance>
	<span>{label}</span>
	<Icon name="lucide:arrow-right" />
</button>
