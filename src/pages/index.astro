---
import Story from '../layouts/Story.astro';
import Hero from '../components/steps/Hero.astro';
import BeforeCity from '../components/steps/BeforeCity.astro';
import Peachtree from '../components/steps/Peachtree.astro';
import Settlement from '../components/steps/Settlement.astro';
import Terminus from '../components/steps/Terminus.astro';
import EarlyAtlanta from '../components/steps/EarlyAtlanta.astro';
import BurntDown from '../components/steps/BurntDown.astro';
import AfterSlavery from '../components/steps/AfterSlavery.astro';
import NewSouth from '../components/steps/NewSouth.astro';
import SweetAuburn from '../components/steps/SweetAuburn.astro';
import MoralRebuilding from '../components/steps/MoralRebuilding.astro';
import Movement from '../components/steps/Movement.astro';
import CityHall from '../components/steps/CityHall.astro';
import MostConnected from '../components/steps/MostConnected.astro';
import SoundsOfAtlanta from '../components/steps/SoundsOfAtlanta.astro';
import WorldWatches from '../components/steps/WorldWatches.astro';
import EveryoneCame from '../components/steps/EveryoneCame.astro';
import StillBuilding from '../components/steps/StillBuilding.astro';
import YourMove from '../components/steps/YourMove.astro';
---

<Story title="A Story of Atlanta">
	<!-- Each .js-slide is one step; the first is active. "continue"
	     advances to the next. Add a step by dropping a new slide here. -->
	<div class="js-slide is-active" id="hero"><Hero /></div>
	<div class="js-slide" id="before-the-city"><BeforeCity /></div>
	<div class="js-slide" id="peachtree"><Peachtree /></div>
	<div class="js-slide" id="settlement"><Settlement /></div>
	<div class="js-slide" id="terminus"><Terminus /></div>
	<div class="js-slide" id="early-atlanta"><EarlyAtlanta /></div>
	<div class="js-slide" id="burnt-down"><BurntDown /></div>
	<div class="js-slide" id="new-south"><NewSouth /></div>
	<div class="js-slide" id="after-slavery"><AfterSlavery /></div>
	<div class="js-slide" id="sweet-auburn"><SweetAuburn /></div>
	<div class="js-slide" id="moral-rebuilding"><MoralRebuilding /></div>
	<div class="js-slide" id="movement"><Movement /></div>
	<div class="js-slide" id="city-hall"><CityHall /></div>
	<div class="js-slide" id="most-connected"><MostConnected /></div>
	<div class="js-slide" id="sounds-of-atlanta"><SoundsOfAtlanta /></div>
	<div class="js-slide" id="world-watches"><WorldWatches /></div>
	<div class="js-slide" id="everyone-came"><EveryoneCame /></div>
	<div class="js-slide" id="still-building"><StillBuilding /></div>
	<div class="js-slide" id="your-move"><YourMove /></div>
</Story>
