---
import '../styles/global.css';

interface Props {
	title?: string;
}
const { title = 'A Story of Atlanta' } = Astro.props;

// Dev-only: dynamically imported so the editing tools (HTML, JS, and CSS)
// are tree-shaken out of production builds entirely.
const EditTools = import.meta.env.DEV
	? (await import('../components/EditTools.astro')).default
	: null;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<!-- Responsive breakpoint as a data attr (so the dev preview can override it).
		     Inline + in <head> so it's set before first paint (no layout flash). -->
		<script is:inline>
			(function () {
				var root = document.documentElement;
				function apply() {
					if (root.dataset.bpLock) return; // dev preview has taken control
					var w = window.innerWidth;
					root.dataset.bp = w <= 640 ? 'phone' : w <= 1024 ? 'tablet' : 'desktop';
				}
				apply();
				window.addEventListener('resize', apply);
			})();
		</script>
		<!-- Cutive: closest Google Fonts match to American Typewriter (web fallback) -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cutive&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body>
		<main class="stage">
			<slot />
		</main>

		<!-- Editing tools render only during `astro dev`, never in production builds -->
		{EditTools && <EditTools />}

		<script>
			import { initStory } from '../scripts/story';
			initStory();
		</script>
	</body>
</html>
